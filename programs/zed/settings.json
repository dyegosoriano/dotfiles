// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "gemini": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
  },
  "agent": {
    "default_profile": "ask",
    "default_model": {
      "provider": "google",
      "model": "gemini-3-flash-preview",
      "enable_thinking": false,
    },
    "model_parameters": [],
    "favorite_models": [],
  },

  "tabs": {
    "close_position": "right",
  },

  "title_bar": {
    "show_branch_icon": true,
  },

  "session": { "trust_all_worktrees": true },

  "icon_theme": { "light": "Symbols Icon Theme", "dark": "Zed (Default)", "mode": "light" },
  "theme": { "dark": "Vesper", "light": "Ayu Light", "mode": "dark" },
  "buffer_font_family": "JetBrainsMonoNL Nerd Font Propo",
  "ui_font_family": "JetBrainsMonoNL Nerd Font Propo",

  "active_pane_modifiers": {
    "inactive_opacity": 1.0,
    "border_size": 0.0,
  },

  "agent_buffer_font_size": 14.0,
  "agent_ui_font_size": 14.0,
  "buffer_font_size": 12,
  "ui_font_size": 12,

  "vim_mode": true,

  "format_on_save": "on",
  // "code_actions_on_save": { "source.organizeImports.biome": true },
  "languages": {
    "JavaScript": { "formatter": { "language_server": { "name": "biome" } } },
    "TypeScript": { "formatter": { "language_server": { "name": "biome" } } },
    "JSONC": { "formatter": { "language_server": { "name": "biome" } } },
    "JSON": { "formatter": { "language_server": { "name": "biome" } } },
  },
}
